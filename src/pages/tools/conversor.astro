---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Conversor de Unidades — km, kg, °C, metros y más"
  description="Convierte unidades de longitud, peso, temperatura y velocidad al instante. Gratis y sin registro."
  canonical="/tools/conversor"
>
<section class="tool-page">
  <div class="container-sm">
    <div class="tool-page-header">
      <div class="breadcrumb"><a href="/">ToolboxES</a><span>›</span><span>Conversor de Unidades</span></div>
      <h1>📐 Conversor de Unidades</h1>
      <p>Convierte entre distintas unidades de medida al instante.</p>
    </div>

    <div class="ad-slot ad-slot-banner">Publicidad</div>

    <div class="calc-card">
      <div class="form-group">
        <label for="categoria">Tipo de conversión</label>
        <select id="categoria">
          <option value="long">📏 Longitud (km, millas, metros, pies...)</option>
          <option value="peso">⚖️ Peso (kg, libras, onzas, toneladas...)</option>
          <option value="temp">🌡️ Temperatura (°C, °F, Kelvin)</option>
          <option value="vel">💨 Velocidad (km/h, mph, m/s)</option>
          <option value="area">📐 Área (m², hectáreas, acres)</option>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="valor">Valor</label>
          <input type="number" id="valor" placeholder="100" step="any" />
        </div>
        <div class="form-group">
          <label for="de">De</label>
          <select id="de"></select>
        </div>
      </div>
      <div class="form-group">
        <label for="a">A</label>
        <select id="a"></select>
      </div>
      <button class="btn-calc" id="convertir">Convertir</button>

      <div class="result-box" id="resultado">
        <h3>Resultado</h3>
        <div class="result-main" id="res-valor">—</div>
        <div class="result-grid">
          <div class="result-item"><div class="rl">Valor original</div><div class="rv" id="res-original">—</div></div>
          <div class="result-item"><div class="rl">Equivale a</div><div class="rv" id="res-equiv">—</div></div>
        </div>
      </div>
    </div>

    <div class="ad-slot ad-slot-banner">Publicidad</div>

    <div class="info-section">
      <h2>¿Cómo usar el conversor?</h2>
      <p>Selecciona el tipo de conversión, introduce el valor, elige la unidad de origen y la unidad destino. El conversor calcula el resultado al instante con máxima precisión.</p>
      <p>Útil para viajes, recetas de cocina, ejercicio físico, trabajos de construcción y cualquier situación en que necesites cambiar de unidades rápidamente.</p>
    </div>
  </div>
</section>
</Layout>

<script>
type UnitMap = Record<string, Record<string, { label: string; factor?: number; toBase?: (v: number) => number; fromBase?: (v: number) => number }>>;

const units: UnitMap = {
  long: {
    km:     { label: 'Kilómetros (km)',   factor: 1 },
    m:      { label: 'Metros (m)',         factor: 0.001 },
    cm:     { label: 'Centímetros (cm)',   factor: 0.00001 },
    mi:     { label: 'Millas (mi)',        factor: 1.60934 },
    yd:     { label: 'Yardas (yd)',        factor: 0.0009144 },
    ft:     { label: 'Pies (ft)',          factor: 0.0003048 },
    in:     { label: 'Pulgadas (in)',      factor: 0.0000254 },
  },
  peso: {
    kg:     { label: 'Kilogramos (kg)',    factor: 1 },
    g:      { label: 'Gramos (g)',         factor: 0.001 },
    lb:     { label: 'Libras (lb)',        factor: 0.453592 },
    oz:     { label: 'Onzas (oz)',         factor: 0.0283495 },
    t:      { label: 'Toneladas (t)',      factor: 1000 },
  },
  temp: {
    c:  { label: '°Celsius (°C)',  toBase: (v) => v,               fromBase: (v) => v },
    f:  { label: '°Fahrenheit (°F)', toBase: (v) => (v-32)*5/9,   fromBase: (v) => v*9/5+32 },
    k:  { label: 'Kelvin (K)',     toBase: (v) => v-273.15,        fromBase: (v) => v+273.15 },
  },
  vel: {
    kmh:  { label: 'km/h',   factor: 1 },
    mph:  { label: 'mph',    factor: 1.60934 },
    ms:   { label: 'm/s',    factor: 3.6 },
    kn:   { label: 'Nudos',  factor: 1.852 },
  },
  area: {
    m2:   { label: 'Metros² (m²)',       factor: 0.000001 },
    km2:  { label: 'Kilómetros² (km²)',  factor: 1 },
    ha:   { label: 'Hectáreas (ha)',     factor: 0.01 },
    ac:   { label: 'Acres (ac)',         factor: 0.00404686 },
    ft2:  { label: 'Pies² (ft²)',        factor: 0.0000000929 },
  },
};

const catEl = document.getElementById('categoria') as HTMLSelectElement;
const deEl  = document.getElementById('de')        as HTMLSelectElement;
const aEl   = document.getElementById('a')         as HTMLSelectElement;

function populate() {
  const cat = catEl.value;
  const opts = units[cat];
  [deEl, aEl].forEach((sel, idx) => {
    sel.innerHTML = '';
    Object.entries(opts).forEach(([k, v]) => {
      const o = document.createElement('option');
      o.value = k; o.textContent = v.label;
      sel.appendChild(o);
    });
    if (idx === 1 && sel.options.length > 1) sel.selectedIndex = 1;
  });
}

catEl.addEventListener('change', populate);
populate();

document.getElementById('convertir')?.addEventListener('click', () => {
  const cat   = catEl.value;
  const val   = parseFloat((document.getElementById('valor') as HTMLInputElement).value);
  const from  = deEl.value;
  const to    = aEl.value;

  if (isNaN(val)) return alert('Introduce un valor numérico.');

  const opts = units[cat];
  const fDef = opts[from];
  const tDef = opts[to];

  let result: number;
  if (fDef.toBase && tDef.fromBase) {
    result = tDef.fromBase(fDef.toBase(val));
  } else {
    const base = val * (fDef.factor || 1);
    result = base / (tDef.factor || 1);
  }

  const decimals = Math.abs(result) < 0.01 ? 6 : Math.abs(result) < 1 ? 4 : 2;
  const resStr = result.toLocaleString('es-ES', { maximumFractionDigits: decimals });

  (document.getElementById('res-valor')   as HTMLElement).textContent = resStr + ' ' + to.toUpperCase();
  (document.getElementById('res-original')as HTMLElement).textContent = val + ' ' + from.toUpperCase();
  (document.getElementById('res-equiv')   as HTMLElement).textContent = resStr + ' ' + to.toUpperCase();
  document.getElementById('resultado')?.classList.add('show');
});
</script>
