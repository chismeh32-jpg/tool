---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Generador de Contraseñas Seguras — Online y Gratis"
  description="Genera contraseñas seguras y aleatorias al instante. Elige longitud, mayúsculas, números y símbolos. 100% gratis y privado."
  canonical="/tools/contraseña"
>
<section class="tool-page">
  <div class="container-sm">
    <div class="tool-page-header">
      <div class="breadcrumb"><a href="/">ToolboxES</a><span>›</span><span>Generador de Contraseñas</span></div>
      <h1>🔐 Generador de Contraseñas</h1>
      <p>Crea contraseñas seguras y aleatorias personalizadas al instante.</p>
    </div>

    <div class="ad-slot ad-slot-banner">Publicidad</div>

    <div class="calc-card">
      <!-- Password display -->
      <div id="password-display" style="background:#f8fafc;border:2px solid #e2e8f0;border-radius:10px;padding:20px 16px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;gap:12px;min-height:64px">
        <code id="password-text" style="font-size:1.2rem;font-weight:700;letter-spacing:0.08em;color:#0f172a;word-break:break-all;flex:1">Haz clic en Generar</code>
        <button id="copy-btn" style="padding:8px 16px;background:#2563eb;color:white;border:none;border-radius:6px;font-weight:600;font-size:0.82rem;cursor:pointer;white-space:nowrap;flex-shrink:0">Copiar</button>
      </div>

      <div class="form-group">
        <label for="longitud">Longitud: <strong id="lon-val">16</strong> caracteres</label>
        <input type="range" id="longitud" min="6" max="64" value="16" style="width:100%;accent-color:#2563eb" />
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px">
        {[
          { id:'mayus',   label:'Mayúsculas (A-Z)',   checked: true },
          { id:'minus',   label:'Minúsculas (a-z)',   checked: true },
          { id:'nums',    label:'Números (0-9)',       checked: true },
          { id:'simbs',   label:'Símbolos (!@#$...)', checked: false },
        ].map(o => (
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:12px;background:#f8fafc;border-radius:8px;border:1.5px solid #e2e8f0">
            <input type="checkbox" id={o.id} checked={o.checked} style="width:16px;height:16px;accent-color:#2563eb" />
            <span style="font-size:0.875rem;font-weight:500">{o.label}</span>
          </label>
        ))}
      </div>

      <button class="btn-calc" id="generar">🔄 Generar contraseña</button>

      <div id="fortaleza" style="margin-top:20px;display:none">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
          <span style="font-size:0.8rem;font-weight:600;color:#64748b">Fortaleza</span>
          <span id="fortaleza-label" style="font-size:0.8rem;font-weight:700"></span>
        </div>
        <div style="height:6px;background:#e2e8f0;border-radius:3px;overflow:hidden">
          <div id="fortaleza-bar" style="height:100%;border-radius:3px;transition:width 0.3s"></div>
        </div>
      </div>
    </div>

    <div class="ad-slot ad-slot-banner">Publicidad</div>

    <div class="info-section">
      <h2>¿Cómo crear una contraseña segura?</h2>
      <p>Una contraseña segura debe tener al menos 12 caracteres y combinar letras mayúsculas, minúsculas, números y símbolos. Cuanto más larga y variada, más difícil es de descifrar.</p>
      <p><strong>Nunca uses</strong> fechas de nacimiento, nombres propios, palabras del diccionario ni la misma contraseña en varias cuentas.</p>
      <p>Todas las contraseñas generadas se crean localmente en tu navegador. No se envían ni almacenan en ningún servidor.</p>
    </div>
  </div>
</section>
</Layout>

<script>
const lonInput  = document.getElementById('longitud') as HTMLInputElement;
const lonVal    = document.getElementById('lon-val') as HTMLElement;
const pwText    = document.getElementById('password-text') as HTMLElement;
const copyBtn   = document.getElementById('copy-btn') as HTMLButtonElement;
const fortaleza = document.getElementById('fortaleza') as HTMLElement;
const fBar      = document.getElementById('fortaleza-bar') as HTMLElement;
const fLabel    = document.getElementById('fortaleza-label') as HTMLElement;

lonInput.addEventListener('input', () => { lonVal.textContent = lonInput.value; });

function generar() {
  const lon   = parseInt(lonInput.value);
  const mayus = (document.getElementById('mayus') as HTMLInputElement).checked;
  const minus = (document.getElementById('minus') as HTMLInputElement).checked;
  const nums  = (document.getElementById('nums')  as HTMLInputElement).checked;
  const simbs = (document.getElementById('simbs') as HTMLInputElement).checked;

  let chars = '';
  if (mayus) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  if (minus) chars += 'abcdefghijklmnopqrstuvwxyz';
  if (nums)  chars += '0123456789';
  if (simbs) chars += '!@#$%^&*()_+-=[]{}|;:,.<>?';

  if (!chars) { alert('Selecciona al menos un tipo de carácter.'); return; }

  let pw = '';
  const arr = new Uint32Array(lon);
  crypto.getRandomValues(arr);
  for (let i = 0; i < lon; i++) pw += chars[arr[i] % chars.length];

  pwText.textContent = pw;

  // Fortaleza
  let score = 0;
  if (lon >= 8)  score++;
  if (lon >= 12) score++;
  if (lon >= 16) score++;
  if (mayus && minus) score++;
  if (nums)  score++;
  if (simbs) score++;

  const levels = [
    { label:'Muy débil',  color:'#ef4444', pct:'16%' },
    { label:'Débil',      color:'#f97316', pct:'33%' },
    { label:'Regular',    color:'#eab308', pct:'50%' },
    { label:'Buena',      color:'#84cc16', pct:'66%' },
    { label:'Fuerte',     color:'#22c55e', pct:'83%' },
    { label:'Muy fuerte', color:'#10b981', pct:'100%' },
  ];
  const lv = levels[Math.min(score, 5)];
  fBar.style.width = lv.pct;
  fBar.style.background = lv.color;
  fLabel.textContent = lv.label;
  fLabel.style.color = lv.color;
  fortaleza.style.display = 'block';
}

document.getElementById('generar')?.addEventListener('click', generar);

copyBtn.addEventListener('click', () => {
  const pw = pwText.textContent || '';
  if (pw === 'Haz clic en Generar') return;
  navigator.clipboard.writeText(pw).then(() => {
    copyBtn.textContent = '✅ Copiado';
    setTimeout(() => { copyBtn.textContent = 'Copiar'; }, 2000);
  });
});

// Generate on load
generar();
</script>
